.gitignore
------------------------------------------------

# Ignore IDE metadata
.vscode/
.idea/

# Ignore compiled and intermediate files
*.pyc
*.so
*.o
*.class

# Ignore temporary files
*.tmp
*.log
*.tmp/

# Ignore IDE generated files
__pycache__/

# Ignore generated files by setup.py
dist/
build/

# Ignore test-related files
tests/__pycache__/
tests/*.class
tests/*.pyc

# Ignore pip cache
pip-wheel-metadata/

# Ignore coverage reports
.coverage
.coverage.*

# Ignore virtualenv markers
__pycache__/venv/